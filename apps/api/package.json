    "@nestjs/swagger": "11.4.4",
    "@tumbfolio/config": "workspace:*",
    "@tumbfolio/db": "workspace:*",
    "@tumbfolio/domain": "workspace:*",
    "@tumbfolio/notebook": "workspace:*",
    "@tumbfolio/storage": "workspace:*",
    "drizzle-orm": "0.45.2",
    "bullmq": "5.77.6",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "compression": "1.8.1",
    "helmet": "8.2.0",
    "ioredis": "5.11.0",
    "pino": "10.3.1",
    "reflect-metadata": "0.2.2",
