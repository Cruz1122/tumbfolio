    "lint": "eslint . --max-warnings=0",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@nestjs/common": "11.1.24",
    "@nestjs/core": "11.1.24",
    "@nestjs/mapped-types": "2.1.1",
