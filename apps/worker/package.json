{
  "name": "@tumbfolio/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "11.1.24",
    "@nestjs/core": "11.1.24",
    "@tumbfolio/config": "workspace:*",
    "@tumbfolio/domain": "workspace:*",
    "bullmq": "5.77.6",
    "fast-xml-parser": "5.8.0",
    "file-type": "22.0.1",
    "ioredis": "5.11.0",
    "jszip": "3.10.1",
    "playwright": "1.60.0",
    "pptxgenjs": "4.0.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "sharp": "0.34.5"
  }
}
