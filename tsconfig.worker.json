{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["es2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "dist-worker",
    "rootDir": ".",
    "jsx": "react-jsx",
    "types": ["node"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["workers/**/*.ts", "lib/**/*.ts", "db/**/*.ts"],
  "exclude": ["node_modules", "app", "components", "tests"]
}
