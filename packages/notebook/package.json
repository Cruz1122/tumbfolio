{
  "name": "@tumbfolio/notebook",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b --clean && tsc -b && tsup src/index.ts --format esm",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@tumbfolio/domain": "workspace:*"
  },
  "devDependencies": {}
}
